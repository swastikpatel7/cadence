# ─── Database ────────────────────────────────────────────────────────────────
# Host ports 5433 and 6380 (not 5432 / 6379) to avoid clashing with
# any local Postgres / Redis instances that may already be running.
DATABASE_URL=postgres://cadence:cadence@localhost:5433/cadence?sslmode=disable
REDIS_URL=redis://localhost:6380/0

# ─── Crypto ──────────────────────────────────────────────────────────────────
# 32-byte AES-256 key, base64-encoded. Generate with:
#   openssl rand -base64 32
ENCRYPTION_KEY=

# ─── Clerk (auth) ────────────────────────────────────────────────────────────
# Get from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# From Clerk → Webhooks → Endpoints (Svix). Used by Next.js webhook handler.
CLERK_WEBHOOK_SECRET=
# JWKS for Go to verify session JWTs. Format: https://<your-instance>.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=
# JWT issuer string. Format: https://<your-instance>.clerk.accounts.dev
CLERK_ISSUER=

# ─── Anthropic ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
# Sonnet 4.6 unless overridden
ANTHROPIC_MODEL=claude-sonnet-4-6

# ─── Strava ──────────────────────────────────────────────────────────────────
# Create app at https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Where Strava redirects after the user approves. Path must match the
# handler registered in apps/api/internal/connections/handlers.go. The
# Strava app's "Authorization Callback Domain" only checks the host, so
# any path on localhost works in dev.
STRAVA_CALLBACK_URL=http://localhost:8080/v1/connections/strava/callback
# Random string used to validate Strava webhook subscription. Generate with:
#   openssl rand -hex 16
STRAVA_WEBHOOK_VERIFY_TOKEN=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Service URLs ────────────────────────────────────────────────────────────
# Public URL the browser uses to call the Go API (used by AI SDK for SSE).
NEXT_PUBLIC_API_URL=http://localhost:8080
# URL Next.js Route Handlers use to reach Go. In Railway, prefer the private
# networking hostname over the public one.
INTERNAL_API_URL=http://localhost:8080
# URL Strava posts webhooks to. Production = https://cadence-api.up.railway.app
WEBHOOK_PUBLIC_URL=http://localhost:8080

# ─── Observability ───────────────────────────────────────────────────────────
# Axiom dataset for OTel traces (production only)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_SERVICE_NAME=

# ─── Runtime ─────────────────────────────────────────────────────────────────
# 'development' | 'production'
APP_ENV=development
LOG_LEVEL=debug
PORT_API=8080
PORT_WEB=3000
